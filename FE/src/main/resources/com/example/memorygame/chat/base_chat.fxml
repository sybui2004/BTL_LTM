<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<fx:root type="VBox" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
         styleClass="base-chat-container" VBox.vgrow="ALWAYS">
    
    <!-- Messages Area - Always takes full available space, grows to fill -->
    <ScrollPane fx:id="scrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="chat-scroll-pane" 
                minHeight="200" prefHeight="400" vbarPolicy="AS_NEEDED">
        <VBox fx:id="messageContainer" spacing="8" styleClass="message-container">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
        </VBox>
    </ScrollPane>
    
    <!-- Input Area - Fixed at bottom, no grow -->
    <HBox fx:id="inputArea" spacing="8" alignment="CENTER" styleClass="input-area" VBox.vgrow="NEVER">
        <padding>
            <Insets top="10" right="15" bottom="10" left="15"/>
        </padding>
        
        <!-- Emoji Button -->
        <Button fx:id="emojiButton" styleClass="emoji-button">
            <graphic>
                <ImageView fitWidth="24" fitHeight="24" preserveRatio="true">
<Image url="@../assets/images/icon/sticker.png"/>
                </ImageView>
            </graphic>
        </Button>
        
        <!-- Input Field -->
        <TextField fx:id="inputField" promptText="" HBox.hgrow="ALWAYS" styleClass="message-input"/>
        
        <!-- Send Button -->
        <Button fx:id="sendButton" styleClass="send-button">
            <graphic>
                <ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                    <!-- Placeholder - bạn sẽ thêm icon send sau -->
                    <Image url="@../assets/images/icon/send_mess.png"/>
                </ImageView>
            </graphic>
        </Button>
    </HBox>
</fx:root>