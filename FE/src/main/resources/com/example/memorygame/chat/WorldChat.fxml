<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  World Chat Layout
  - Chat toàn server cho tất cả người chơi
  - Sử dụng ChatComponent để hiển thị và xử lý tin nhắn
-->
<VBox fx:id="root" xmlns="http://javafx.com/javafx/11.0.1" 
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.memorygame.controller.chat.WorldChatController"
    prefWidth="400.0" prefHeight="600.0"
    minWidth="400.0" minHeight="600.0"
    styleClass="world-chat-container">
    <stylesheets>
        <URL value="@chatstyles/BaseChatStyle.css"/>
        <URL value="@chatstyles/WorldChatStyle.css"/>
    </stylesheets>
    
    <!-- Header với title -->
    <BorderPane styleClass="chat-header">
        <padding>
            <Insets top="10.0" right="15.0" bottom="10.0" left="15.0"/>
        </padding>
        <center>
            <Label text="🌍 World Chat" styleClass="chat-title" BorderPane.alignment="CENTER"/>
        </center>
    </BorderPane>
    
    <!-- Container cho ChatComponent - sẽ được thêm vào từ controller -->
    <VBox fx:id="chatContainer" VBox.vgrow="ALWAYS" styleClass="chat-content">
    </VBox>
</VBox>
