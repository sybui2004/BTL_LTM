<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<!--
  Match Chat Layout
  - Chat giữa 2 người chơi trong trận
  - Góc dưới trái: tin của người gửi + ô nhập
  - Góc trên phải: tin của đối thủ
-->

<VBox xmlns="http://javafx.com/javafx/11.0.1" 
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.memorygame.controller.chat.MatchChatController"
    fx:id="rootBox"
    styleClass="match-chat-container"
    alignment="TOP_LEFT"
    pickOnBounds="false" mouseTransparent="false">
    <stylesheets>
                <URL value="@chatstyles/BaseChatStyle.css"/>
                <URL value="@chatstyles/MatchChatStyle.css"/>
                <!-- Fallback for case differences when packaged -->
                <URL value="@ChatStyles/BaseChatStyle.css"/>
                <URL value="@ChatStyles/MatchChatStyle.css"/>
    </stylesheets>
    
    
    <!-- AnchorPane để đặt chat ở các góc màn hình -->
    <AnchorPane fx:id="chatAnchor" styleClass="match-chat-anchor" pickOnBounds="false" mouseTransparent="false" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
        

        <!-- Góc dưới trái: Panel người gửi (messages + input) với StackPane overlay animation -->
<StackPane fx:id="leftPane" styleClass="left-pane"
    AnchorPane.bottomAnchor="10" AnchorPane.leftAnchor="10"
    maxWidth="350" minWidth="280"
    prefHeight="350" maxHeight="400"
    mouseTransparent="false" pickOnBounds="false">
    <!-- Góc dưới trái: Panel người gửi (messages + input) -->
        <VBox spacing="0" StackPane.alignment="TOP_LEFT">
            
            <!-- Khu vực tin nhắn -->
            <ScrollPane fx:id="leftScroll" fitToWidth="true" prefHeight="250" maxHeight="300" 
                        VBox.vgrow="ALWAYS" styleClass="chat-scroll-pane"
                        style="-fx-background-color: transparent;">
                <VBox fx:id="leftMessageContainer" spacing="8" styleClass="message-container left-messages"/>
            </ScrollPane>
            
            <!-- Khu vực nhập liệu với header người chơi -->
            <HBox fx:id="leftInputArea" spacing="8" alignment="CENTER_LEFT" styleClass="input-area player-header"
                  style="-fx-background-color: rgb(255, 255, 255); -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: transparent; -fx-border-width: 0;">
                <padding>
                    <Insets top="8" right="12" bottom="8" left="12"/>
                </padding>
                <ImageView fx:id="leftPlayerAvatar" fitWidth="48" fitHeight="48" preserveRatio="true" styleClass="player-header-avatar" />
                <VBox fx:id="leftPlayerInputContainer" spacing="2" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <Label fx:id="leftPlayerName" text="Me" styleClass="player-header-name" />
                    <TextField fx:id="inputField" promptText="" styleClass="message-input"/>
                </VBox>
                <VBox alignment="BOTTOM_RIGHT">
                    <Button fx:id="sendButton" styleClass="send-button"
                            style="-fx-background-color: transparent; -fx-background-radius: 0; -fx-border-radius: 0; -fx-padding: 0; -fx-border-width: 0; -fx-border-color: transparent;">
                        <graphic>
                            <ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                                <Image url="@../assets/images/icon/send_mess.png"/>
                            </ImageView>
                        </graphic>
                    </Button>
                </VBox>
                <!-- Sticker Button -->
                <VBox alignment="BOTTOM_RIGHT">
                <Button fx:id="stickerMatchButton" styleClass="sticker-match-button">
                    <graphic>
                        <ImageView fitWidth="32" fitHeight="32" preserveRatio="true">
                            <Image url="@../assets/images/icon/sticker_match.png"/>
                        </ImageView>
                    </graphic>
                </Button>
                </VBox>
            </HBox>
        </VBox>
    <AnchorPane fx:id="leftAnimationLayer" pickOnBounds="false" mouseTransparent="true"
        style="-fx-background-color: transparent;" />
</StackPane>

        <!-- Góc trên phải: Panel đối thủ (chỉ tin nhắn) với StackPane overlay animation -->
<StackPane fx:id="rightPane" styleClass="right-pane"
    AnchorPane.topAnchor="40" AnchorPane.rightAnchor="10"
    maxWidth="350" minWidth="280"
    prefHeight="350" maxHeight="400"
    mouseTransparent="false" pickOnBounds="false">
    <VBox spacing="6" StackPane.alignment="TOP_RIGHT">
        <!-- Header người chơi: avatar + tên -->
        <HBox styleClass="player-header" alignment="CENTER_RIGHT" spacing="8">
            <padding>
                <Insets top="8.0" right="8.0" bottom="8.0" left="8.0"/>
            </padding>
            <Label fx:id="rightPlayerName" text="Opponent" styleClass="player-header-name" />
            <ImageView fx:id="rightPlayerAvatar" fitWidth="48" fitHeight="48" preserveRatio="true" styleClass="player-header-avatar" />
        </HBox>
        <!-- Khu vực tin nhắn -->
        <ScrollPane fx:id="rightScroll" fitToWidth="true" prefHeight="300" maxHeight="350" 
                    VBox.vgrow="ALWAYS" styleClass="chat-scroll-pane"
                    style="-fx-background-color: transparent; -fx-padding: 0;">
            <VBox fx:id="rightMessageContainer" spacing="8" styleClass="message-container right-messages"
                  style="-fx-padding: 2 0 2 0; -fx-alignment: TOP_RIGHT;"/>
        </ScrollPane>
    </VBox>
    <AnchorPane fx:id="rightAnimationLayer" pickOnBounds="false" mouseTransparent="true"
        style="-fx-background-color: transparent;" />
</StackPane>
    </AnchorPane>
    
    
</VBox>
